MONGO_URI=mongodb://localhost:27017/studyhub
JWT_SECRET=your_secret_key

# Optional — only needed for forgot-password emails to actually send.
# EMAIL_USER: a Gmail address. EMAIL_PASS: a 16-character Gmail "App Password"
# (Google Account -> Security -> 2-Step Verification -> App passwords), NOT
# your real Gmail password. Leave both blank to keep the dev fallback (the
# reset link is returned directly in the API response instead of emailed).
EMAIL_USER=
EMAIL_PASS=
CLIENT_URL=http://localhost:3000